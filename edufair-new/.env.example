# Production Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_NAME=EduFair
NEXT_PUBLIC_APP_URL=https://edufair.com
NEXT_PUBLIC_ENVIRONMENT=production
NODE_ENV=production

# ============================================
# SUPABASE CONFIGURATION
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-secure-random-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# EMAIL SERVICE
# ============================================
# SendGrid (recommended)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@edufair.com

# Alternative: Nodemailer (Gmail, custom SMTP, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=EduFair
EMAIL_FROM_EMAIL=noreply@edufair.com

# Disable emails in development
DISABLE_EMAILS=false

# ============================================
# PAYMENT INTEGRATION
# ============================================
# Stripe (for future premium features)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key

# ============================================
# EXTERNAL APIs
# ============================================
# WhatsApp Chatbot (optional)
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_PHONE_NUMBER_ID=your-phone-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ============================================
# SECURITY
# ============================================
# CORS Settings
NEXT_PUBLIC_CORS_ORIGINS=https://edufair.com,https://www.edufair.com,https://admin.edufair.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-project-id.ingest.sentry.io/your-project-key

# ============================================
# ANALYTICS
# ============================================
NEXT_PUBLIC_GA_ID=G-your-google-analytics-id
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_GAMIFICATION=true
ENABLE_WHATSAPP_CHATBOT=true
ENABLE_FEE_CALCULATOR=true
ENABLE_INSTITUTION_DASHBOARD=true
ENABLE_PREMIUM_FEATURES=true

# ============================================
# DATABASE BACKUPS & MAINTENANCE
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30

# ============================================
# CACHING (Redis - optional for production scale)
# ============================================
REDIS_URL=redis://username:password@localhost:6379
REDIS_TTL=3600

# ============================================
# DEMO/DEVELOPMENT MODE
# ============================================
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEBUG_MODE=false
